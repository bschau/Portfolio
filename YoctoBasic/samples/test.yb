10 rem this is a comment

print "Starting"
let a = 4
let z = (20 * a) / 10
print "Enter a and z:"
input a, z

print "a is ", a, "     z is ", z

if a < z then print "a is less"
if a <= z then print "a is still less"
if a > z then print "will not happen"
if z > a then print "z is more"
if z >= a then print "z is still more"
if a <> z then print "a is different from z"
if a = z then print "will not happen"
if a = a then print "a equals itself"
if z = z then print "z equals itself"
if a <> a then print "will not happen"
if z <> z then print "will not happen"
goto 30
print "not shown"
30 gosub 40
print "the end"
end
40 print "before the end"
return


